# WhatsApp Bot .gitignore

# Authentication data (local storage)
.wwebjs_auth/
.wwebjs_auth
wwebjs_auth/

# Logs
bot.log
*.log

# Node modules
node_modules/
package-lock.json

# Environment variables
.env
.env.local
.env.*.local

# OS files
.DS_Store
Thumbs.db
*.swp
*.swo

# IDE
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# Chrome/Puppeteer cache
chrome-data/
*.deb

# Session files
*.session
session.json

# Temporary files
tmp/
temp/
*.tmp
